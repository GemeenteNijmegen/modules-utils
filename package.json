{
  "name": "@gemeentenijmegen/utils",
  "repository": {
    "type": "git",
    "url": "https://github.com/GemeenteNijmegen/modules-utils.git"
  },
  "scripts": {
    "build": "projen build",
    "bump": "projen bump",
    "clobber": "projen clobber",
    "compile": "projen compile",
    "default": "projen default",
    "eject": "projen eject",
    "eslint": "projen eslint",
    "package": "projen package",
    "post-compile": "projen post-compile",
    "post-upgrade": "projen post-upgrade",
    "pre-compile": "projen pre-compile",
    "release": "projen release",
    "test": "projen test",
    "test:watch": "projen test:watch",
    "unbump": "projen unbump",
    "upgrade": "projen upgrade",
    "watch": "projen watch",
    "projen": "projen"
  },
  "devDependencies": {
    "@gemeentenijmegen/projen-project-type": "^1.12.7",
    "@stylistic/eslint-plugin": "^2",
    "@testcontainers/localstack": "^10.28.0",
    "@types/jest": "^28.1.8",
    "@types/node": "^14",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "aws-sdk-client-mock": "^2.2.0",
    "commit-and-tag-version": "^12",
    "constructs": "^10.0.0",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^27",
    "jest-junit": "^16",
    "projen": "^0.99.52",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/client-secrets-manager": "^3.1040.0",
    "@aws-sdk/client-ssm": "^3.1040.0",
